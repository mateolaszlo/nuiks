STUDYVAULT_PUBLIC_BASE_URL=http://localhost:8080
STUDYVAULT_GATEWAY_BIND_ADDRESS=0.0.0.0
# Local/dev-friendly auth throttling for manual testing and Playwright.
# Review and tighten these before any shared or internet-exposed deployment.
STUDYVAULT_AUTH_RATE=360r/m
STUDYVAULT_AUTH_BURST=90
STUDYVAULT_AUTH_NAV_RATE=480r/m
STUDYVAULT_AUTH_NAV_BURST=180
STUDYVAULT_UPLOAD_RATE=50r/m
STUDYVAULT_UPLOAD_BURST=50
STUDYVAULT_SEARCH_RATE=80r/m
STUDYVAULT_SEARCH_BURST=50
STUDYVAULT_ADMIN_RATE=150r/m
STUDYVAULT_ADMIN_BURST=50
STUDYVAULT_ADMIN_BIND_ADDRESS=127.0.0.1
STUDYVAULT_DB_BIND_ADDRESS=127.0.0.1
KEYCLOAK_REALM=studyvault
KEYCLOAK_ISSUER_URL=${STUDYVAULT_PUBLIC_BASE_URL}/realms/studyvault
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/studyvault/protocol/openid-connect/certs
KEYCLOAK_FRONTEND_URL=${STUDYVAULT_PUBLIC_BASE_URL}/realms/studyvault
KEYCLOAK_CLIENT_ID=studyvault-frontend
KEYCLOAK_CLIENT_SECRET=dummy-client-secret
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
KEYCLOAK_ADMIN_USERNAME=${KC_BOOTSTRAP_ADMIN_USERNAME}
KEYCLOAK_ADMIN_PASSWORD=${KC_BOOTSTRAP_ADMIN_PASSWORD}
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=studyvault-keycloak-db-password-change-me
STUDYVAULT_AUTH_DISABLED=false
CATALOG_INTERNAL_URL=http://catalog-service:8000
SEARCH_INTERNAL_URL=http://search-service:8000
ACTIVITY_INTERNAL_URL=http://activity-service:8000
STUDYVAULT_INTERNAL_TOKEN=studyvault-internal-token-change-me
CATALOG_DATABASE_URL=postgresql+psycopg://studyvault:studyvault@postgres:5432/studyvault
SEARCH_MONGODB_URL=mongodb://mongodb:27017
ACTIVITY_MONGODB_URL=mongodb://mongodb:27017
# Persistence boundary warning:
# If FILE_S3_* points at a dedicated external MinIO/S3 bucket, preserve Keycloak
# plus catalog Postgres state too. StudyVault ownership is tied to the Keycloak
# subject id (`sub` / owner_id), not just username or email.
# For the optional local Compose MinIO profile, use:
FILE_S3_ENDPOINT=http://minio:9000
FILE_S3_ACCESS_KEY=minioadmin
FILE_S3_SECRET_KEY=minioadmin
FILE_S3_BUCKET=studyvault-files


# Dedicated MinIO or other S3-compatible endpoint used by file-service.
# When using this mode, normal upgrades should be `docker compose up -d --build`.
# Avoid `docker compose down -v` unless you intentionally want to wipe Keycloak,
# catalog metadata, and any local persistent volumes together.
# FILE_S3_ENDPOINT=http://10.0.0.10:9000
# FILE_S3_ACCESS_KEY=replace-with-minio-access-key
# FILE_S3_SECRET_KEY=replace-with-minio-secret-key
# FILE_S3_BUCKET=studyvault-files
# FILE_S3_REGION=us-east-1
ELASTICSEARCH_URL=http://elasticsearch:9200
STORAGE_USAGE_RUN_MODE=loop
STORAGE_USAGE_INTERVAL_SECONDS=3600
STORAGE_USAGE_INDEX_PREFIX=studyvault-storage
MAX_REGISTERED_USERS=20 # Instance-wide registration cap for future Keycloak registration enforcement.
USER_STORAGE_QUOTA_BYTES=10737418240 # 10 GiB default per-user quota, adjust as needed.
