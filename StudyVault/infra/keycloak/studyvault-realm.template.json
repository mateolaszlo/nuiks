{
  "realm": "studyvault",
  "enabled": true,
  "registrationAllowed": true,
  "rememberMe": true,
  "registrationEmailAsUsername": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "verifyEmail": false,
  "eventsEnabled": true,
  "eventsListeners": [
    "jboss-logging"
  ],
  "enabledEventTypes": [
    "REGISTER",
    "LOGIN"
  ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "roles": {
    "realm": [
      {
        "name": "studyvault_admin",
        "description": "StudyVault application administrator"
      }
    ]
  },
  "clients": [
    {
      "clientId": "studyvault-frontend",
      "name": "StudyVault Frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "__STUDYVAULT_FRONTEND_REDIRECT_URI__"
      ],
      "webOrigins": [
        "__STUDYVAULT_FRONTEND_WEB_ORIGIN__"
      ],
      "protocolMappers": [
        {
          "name": "frontend-audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "studyvault-frontend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256"
      }
    }
  ],
  "users": [
    {
      "username": "demo",
      "enabled": true,
      "email": "demo@studyvault.local",
      "firstName": "Demo",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "demo123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "offline_access",
        "uma_authorization"
      ]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@studyvault.local",
      "firstName": "StudyVault",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "offline_access",
        "uma_authorization",
        "studyvault_admin"
      ]
    }
  ]
}
